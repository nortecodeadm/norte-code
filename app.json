{
  "expo": {
    "name": "Norte Code",
    "slug": "norte-code",
    "owner": "norte.code.adm",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "nortecode",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1F5F3F"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.nortecode.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#1F5F3F"
      },
      "package": "com.nortecode.app",
      "edgeToEdgeEnabled": false,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      ["@sentry/react-native", {
        "organization": "norte-code-adm",
        "project": "norte-code"
      }]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "062b92be-bf65-415f-8628-05304bb2d3dc"
      }
    }
  }
}
